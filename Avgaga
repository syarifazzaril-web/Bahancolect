-- MENCARI BASE HANYA 1 KALI (LOCK SYSTEM)
local LockedBaseName = nil
local LockedPoints = nil

for baseName, points in pairs(Bases) do
    local dist = (initialPos.Position - Vector3.new(points[1][1], points[1][2], points[1][3])).Magnitude
    if dist < RANGE_DETEKSI then
        LockedBaseName = baseName
        LockedPoints = points
        break
    end
end

if not LockedBaseName then
    warn("Gagal: Berdirilah lebih dekat ke base sebelum execute!")
    return
end

print(">>> BASE LOCKED: " .. LockedBaseName)

-- LOGIC LOOPING
task.spawn(function()
    while _G.autocollect do
        print("Siklus dimulai di " .. LockedBaseName)
        
        -- Muter di base yang sudah di-lock tadi
        for _, coord in ipairs(LockedPoints) do
            if not _G.autocollect then break end
            rootPart.CFrame = CFrame.new(coord[1], coord[2], coord[3])
            task.wait(DELAY_ANTAR_TITIK)
        end

        -- Balik ke posisi awal
        if _G.autocollect then
            print("Putaran selesai, balik ke awal.")
            rootPart.CFrame = initialPos
            
            -- Menunggu 30 detik
            for i = 1, COOLDOWN_LOOP do
                if not _G.autocollect then break end
                task.wait(1)
            end
        end
    end
    print(">>> Script Berhenti.")
end)
